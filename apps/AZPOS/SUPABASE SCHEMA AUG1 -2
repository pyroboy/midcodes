  {
    "name": "FUNCTION: check_stock_alerts",
    "definition": "CREATE FUNCTION check_stock_alerts()\\nRETURNS trigger\\nLANGUAGE plpgsql\\nAS $$\\nCREATE OR REPLACE FUNCTION public.check_stock_alerts()\n RETURNS trigger\n LANGUAGE plpgsql\n SECURITY DEFINER\nAS $function$\nDECLARE\n    product_record RECORD;\nBEGIN\n    SELECT name, min_stock_level, max_stock_level\n    INTO product_record\n    FROM public.products\n    WHERE id = NEW.id;\n\n    UPDATE public.inventory_alerts\n    SET is_acknowledged = true, acknowledged_at = now(), message = message || ' (Auto-resolved)'\n    WHERE product_id = NEW.id AND is_acknowledged = false;\n\n    IF NEW.stock_quantity <= product_record.min_stock_level AND NEW.stock_quantity > 0 THEN\n        INSERT INTO public.inventory_alerts (product_id, alert_type, current_value, threshold_value, message)\n        VALUES (NEW.id, 'low_stock', NEW.stock_quantity, product_record.min_stock_level, 'Product ' || product_record.name || ' is running low on stock.');\n    END IF;\n    \n    IF NEW.stock_quantity <= 0 THEN\n        INSERT INTO public.inventory_alerts (product_id, alert_type, current_value, threshold_value, message)\n        VALUES (NEW.id, 'out_of_stock', 0, 0, 'Product ' || product_record.name || ' is out of stock.');\n    END IF;\n\n    IF product_record.max_stock_level IS NOT NULL AND NEW.stock_quantity > product_record.max_stock_level THEN\n        INSERT INTO public.inventory_alerts (product_id, alert_type, current_value, threshold_value, message)\n        VALUES (NEW.id, 'overstock', NEW.stock_quantity, product_record.max_stock_level, 'Product ' || product_record.name || ' is overstocked.');\n    END IF;\n    \n    RETURN NEW;\nEND;\n$function$\n\\n$$;"
  },
  {
    "name": "FUNCTION: create_expiration_alerts",
    "definition": "CREATE FUNCTION create_expiration_alerts()\\nRETURNS void\\nLANGUAGE plpgsql\\nAS $$\\nCREATE OR REPLACE FUNCTION public.create_expiration_alerts()\n RETURNS void\n LANGUAGE plpgsql\nAS $function$\nBEGIN\n    INSERT INTO public.inventory_alerts (product_id, alert_type, message, current_value)\n    SELECT \n        pb.product_id,\n        'expiring_soon',\n        'Batch ' || pb.batch_number || ' for product ' || p.name || ' is expiring on ' || to_char(pb.expiration_date, 'YYYY-MM-DD') || '.',\n        pb.quantity_on_hand\n    FROM public.product_batches pb\n    JOIN public.products p ON p.id = pb.product_id\n    WHERE pb.expiration_date BETWEEN now() AND now() + interval '30 days'\n      AND pb.quantity_on_hand > 0\n    ON CONFLICT (product_id, alert_type) WHERE is_acknowledged = false DO NOTHING;\n\n    INSERT INTO public.inventory_alerts (product_id, alert_type, message, current_value)\n    SELECT \n        pb.product_id,\n        'expired',\n        'Batch ' || pb.batch_number || ' for product ' || p.name || ' expired on ' || to_char(pb.expiration_date, 'YYYY-MM-DD') || '.',\n        pb.quantity_on_hand\n    FROM public.product_batches pb\n    JOIN public.products p ON p.id = pb.product_id\n    WHERE pb.expiration_date <= now()\n      AND pb.quantity_on_hand > 0\n    ON CONFLICT (product_id, alert_type) WHERE is_acknowledged = false DO NOTHING;\nEND;\n$function$\n\\n$$;"
  },
  {
    "name": "FUNCTION: sync_product_stock",
    "definition": "CREATE FUNCTION sync_product_stock()\\nRETURNS trigger\\nLANGUAGE plpgsql\\nAS $$\\nCREATE OR REPLACE FUNCTION public.sync_product_stock()\n RETURNS trigger\n LANGUAGE plpgsql\nAS $function$\nBEGIN\n    -- Update product stock_quantity based on inventory_items\n    UPDATE products \n    SET stock_quantity = (\n        SELECT COALESCE(SUM(quantity_on_hand), 0)\n        FROM inventory_items \n        WHERE product_id = NEW.product_id\n    )\n    WHERE id = NEW.product_id;\n    \n    RETURN NEW;\nEND;\n$function$\n\\n$$;"
  },
  {
    "name": "FUNCTION: update_updated_at_column",
    "definition": "CREATE FUNCTION update_updated_at_column()\\nRETURNS trigger\\nLANGUAGE plpgsql\\nAS $$\\nCREATE OR REPLACE FUNCTION public.update_updated_at_column()\n RETURNS trigger\n LANGUAGE plpgsql\nAS $function$\nBEGIN\n    NEW.updated_at = now();\n    RETURN NEW;\nEND;\n$function$\n\\n$$;"

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/court_sniper"

# Authentication
BETTER_AUTH_SECRET="your-secret-key-here-min-32-chars"
BETTER_AUTH_URL="http://localhost:5175"

# Maps
VITE_MAPBOX_TOKEN="pk.YOUR_PUBLIC_MAPBOX_TOKEN"

# PayMongo
PAYMONGO_SECRET_KEY="sk_live_YOUR_SECRET_KEY"

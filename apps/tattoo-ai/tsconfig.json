{
	"compilerOptions": {
		"moduleResolution": "bundler",
		"allowSyntheticDefaultImports": true,
		"allowJs": true,
		"checkJs": false,
		"target": "ESNext",
		"module": "ESNext",
		"lib": ["ESNext", "DOM", "DOM.Iterable"],
		"types": ["vitest/globals"],
		"strict": true,
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"baseUrl": ".",
		"paths": {
			"$lib/*": ["src/lib/*"],
			"$routes/*": ["src/routes/*"]
		}
	},
	"include": ["src"],
	"exclude": ["node_modules", "build", "dist"]
}

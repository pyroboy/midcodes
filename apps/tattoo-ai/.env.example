# Database
DATABASE_URL=postgresql://user:password@host/dbname

# Auth
BETTER_AUTH_SECRET=your-secret-key-here
BETTER_AUTH_URL=http://localhost:5176

# AI
GROQ_API_KEY=your-groq-api-key

# Facebook Messenger
FB_PAGE_ACCESS_TOKEN=your-fb-page-access-token

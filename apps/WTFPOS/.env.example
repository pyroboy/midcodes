# ─── Cross-Branch Kitchen Aggregation ─────────────────────────────────────────
# Used by /api/sse/aggregate to pull live order streams from branch servers.
# Set these on the owner/manager device (or any device using locationId=all).
# Leave blank if running in single-branch mode.
#
# Format: http://<LAN_IP>:<PORT>  (no trailing slash)
# Example: if Tagbilaran terminal is at 192.168.1.10 running on port 3000:
#
TAG_SSE_URL=http://192.168.1.10:3000
PGL_SSE_URL=http://192.168.1.11:3000

# For local dev: run two instances on different ports
# TAG_SSE_URL=http://localhost:5173
# PGL_SSE_URL=http://localhost:5174

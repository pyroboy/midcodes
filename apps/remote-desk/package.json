{
  "name": "remote-desk",
  "version": "0.1.0",
  "description": "FlowWork - Workforce management platform with GPS clock-in, task management, and inventory tracking",
  "type": "module",
  "scripts": {
    "dev": "vite dev --host --port 5174",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --plugin-search-dir . --check . && eslint .",
    "format": "prettier --plugin-search-dir . --write .",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "svelte": "^5.0.0",
    "@sveltejs/kit": "^2.0.0",
    "rxdb": "^16.0.0",
    "dexie": "^4.0.0",
    "@neondatabase/serverless": "^1.0.0",
    "drizzle-orm": "^0.31.0",
    "better-auth": "^1.5.0",
    "tailwindcss": "^3.4.0",
    "bits-ui": "^0.21.0",
    "sveltekit-superforms": "^2.0.0",
    "zod": "^3.22.0",
    "lucide-svelte": "^0.378.0",
    "date-fns": "^3.0.0",
    "clsx": "^2.0.0",
    "class-variance-authority": "^0.7.0"
  },
  "devDependencies": {
    "@sveltejs/adapter-cloudflare": "^4.0.0",
    "@sveltejs/vite-plugin-svelte": "^3.0.0",
    "svelte-check": "^3.6.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0",
    "prettier": "^3.1.0",
    "prettier-plugin-svelte": "^3.0.0",
    "eslint": "^8.54.0",
    "eslint-plugin-svelte": "^2.34.0",
    "drizzle-kit": "^0.20.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "@tailwindcss/typography": "^0.5.0"
  }
}
